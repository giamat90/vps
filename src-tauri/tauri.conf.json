{
    "$schema":  "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName":  "Vocal Practice Studio",
    "version":  "0.1.32",
    "identifier":  "com.giacominomatzeu.vps",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:5173",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Vocal Practice Studio",
                                    "width":  1200,
                                    "height":  800,
                                    "minWidth":  900,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false
                                }
                            ],
                "security":  {
                                 "csp":  null,
                                 "assetProtocol":  {
                                                       "enable":  true,
                                                       "scope":  [
                                                                     "$HOME/.vps/**"
                                                                 ]
                                                   }
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "externalBin":  [
                                       "binaries/vps-sidecar"
                                   ],
                   "resources":  [
                                     "resources/third-party-notices/**/*"
                                 ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "createUpdaterArtifacts":  true
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxOTc2MEU4MzIwQTkyODEKUldTQmtnb3k2R0NYd2JTSjNqRGdiZ0Y3UDgyWm9UdVlDOElGZEJvQ0gzWlozSlpOenJYYzNOcngK",
                                    "endpoints":  [
                                                      "https://github.com/giamat90/vps/releases/latest/download/latest.json"
                                                  ]
                                }
                }
}